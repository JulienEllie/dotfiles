{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -eo pipefail

if [ ! -r /etc/os-release ]; then
  exit 0
fi
. /etc/os-release
case " ${ID:-} ${ID_LIKE:-} " in
  *" debian "*|*" ubuntu "*) ;;
  *) exit 0 ;;
esac

ARCH=$(dpkg --print-architecture)

# Go: install latest stable from go.dev (re-run script with --force to upgrade)
GO_LATEST=$(curl -fsSL "https://go.dev/VERSION?m=text" | head -n1 | sed 's/^go//')
if ! /usr/local/go/bin/go version 2>/dev/null | grep -q "go${GO_LATEST} "; then
  echo "installing Go ${GO_LATEST} (${ARCH})..."
  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' EXIT
  curl -fsSL "https://go.dev/dl/go${GO_LATEST}.linux-${ARCH}.tar.gz" -o "${tmp}/go.tar.gz"
  sudo rm -rf /usr/local/go
  sudo tar -C /usr/local -xzf "${tmp}/go.tar.gz"
fi

# rustup: user-scoped, manages toolchains itself (run `rustup update` to upgrade)
if [ ! -x "$HOME/.cargo/bin/rustup" ]; then
  echo "installing rustup..."
  curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --no-modify-path
fi

# SDKMAN!: user-scoped JVM ecosystem manager (run `sdk update` to upgrade)
if [ ! -d "$HOME/.sdkman" ]; then
  echo "installing SDKMAN!..."
  curl -fsSL "https://get.sdkman.io?rcupdate=false" | bash
fi

# install latest Amazon Corretto + latest Kotlin via SDKMAN! (no-op if already installed)
if [ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]; then
  # shellcheck disable=SC1091
  source "$HOME/.sdkman/bin/sdkman-init.sh"
  corretto=$(sdk list java 2>/dev/null \
    | awk -F'|' '/amzn/ && !/ea/ {gsub(/[[:space:]]/,"",$NF); print $NF}' \
    | sort -V | tail -1)
  if [ -n "$corretto" ]; then
    yes | sdk install java "$corretto" || true
    sdk default java "$corretto" || true
  fi
  yes | sdk install kotlin || true
fi
{{ end -}}
